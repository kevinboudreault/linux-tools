#!/usr/bin/env zsh

# --- Configuration & Styling ---
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

wp_check_logs() {
    # Validate environment
    if ! command -v docker &> /dev/null; then
        echo -e "${RED}Error: Docker is not installed.${NC}"
        return 1
    fi  

    if ! docker info &> /dev/null; then
        echo -e "${RED}Error: Docker daemon is not running. Please start Docker.${NC}"
        return 1
    fi  

    local CONTAINER_NAME="${WP_CONTAINER_NAME}"
    if [[ -z "$CONTAINER_NAME" ]]; then
        while [[ -z "$CONTAINER_NAME" ]]; do
            echo -n "Enter the running WordPress container Name or ID: "
            read CONTAINER_NAME
        done
    fi  

    # Verify container is active using a more direct check
    if ! docker ps --filter "name=(${CONTAINER_NAME})" --query "status=running" &> /dev/null; then
         # Fallback to name check if filter yields nothing (compatibility)
         if ! docker ps --format '{{.Names}}' | grep -q "$CONTAINER_NAME"; then
            echo -e "${RED}Error: Container '$CONTAINER_NAME' is not running or does not exist.${NC}"
            return 1
         fi
    fi  

    # Interactive setup cleaner options
    echo -e "\n${BLUE}--- Log Configuration ---${NC}"
    echo "1) All Logs (Errors + Warnings highlighted)"
    echo "2) Errors Only"
    echo "3) Warnings Only"
    echo -n "Enter choice [1-3]: "
    read LOG_CHOICE

    echo -n "Enter search term (leave blank for all): "
    read SEARCH_TERM
    # Trim whitespace if any
    SEARCH_TERM=$(echo "$SEARCH_TERM" | xargs)

    echo -n "How many lines to tail? [100]: "
    read TAIL_LINES
    : ${TAIL_LINES:=100}

    echo -e "\n${BLUE}Fetching logs from $CONTAINER_NAME...${NC}"
    echo "------------------------------------------------"

    # Optimization: Construct the base command without 'eval' and 
    # consolidate processing logic to reduce pipe overhead.
    local BASE_CMD="docker logs --tail ${TAIL_LINES} ${CONTAINER_NAME}"
    
    # Filter construction
    local FILTER_EXPR=""
    case "$LOG_CHOICE" in
        1) # All Logs with color mapping
            $BASE_CMD 2>&1 | awk -v r="$RED" -v y="$YELLOW" -v nc="$NC" -v s="${SEARCH_TERM:-.}" '
                tolower($0) ~ /error|fatal|notice/ {print r $0 nc; next}
                tolower($0) ~ /warning/ {print y $0 nc; next}
                $0 ~ s {print $0}
            '
            ;;
        2) # Errors Only
            echo -e "${RED}[FILTER: ERRORS ONLY]${NC}"
            $BASE_CMD 2>&1 | grep -Ei "error|fatal|notice" | grep -i "${SEARCH_TERM:-.}"
            ;;
        3) # Warnings Only
            echo -e "${YELLOW}[FILTER: WARNINGS ONLY]${NC}"
            $BASE_CMD 2>&1 | grep -i "warning" | grep -i "${SEARCH_TERM:-.}"
            ;;
        *)
            echo -e "${RED}Invalid choice selection.${NC}"
            return 1
            ;;
    esac

    if [[ $? -eq 0 ]]; then
        echo -e "\n------------------------------------------------"
        echo "Log check complete."
    else
        echo -e "\n${RED}Error: Failed to retrieve logs.${NC}"
        return 1
    fi  
}

wp_check_logs