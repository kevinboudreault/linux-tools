#!/usr/bin/env zsh
# shellcheck disable=SC1091,SC2155
# Optimized Symfony Developer Wrapper for Zsh

setopt ERR_EXIT    # Exit on first error
setopt ERR_RETURN  # Return command exit status

# =============================================================================
# UTILITY FUNCTIONS
# =============================================================================

# Log to stderr with timestamp (useful for debugging)
_log() {
    local timestamp
    timestamp=$(date '+%F %T')
    printf '%s\n' "[${timestamp}] $*" >&2
}

# Check if a command exists and works
_cmd_exists() {
    local cmd="$1"
    if command -v "$cmd" >/dev/null 2>&1; then
        return 0
    fi
    return 1
}

# Safe file existence check with context
_file_exists() {
    local file="$1"
    if [[ -f "$file" ]]; then
        return 0
    fi
    return 1
}

# Parse docker services without external tools
_parse_docker_services() {
    if _cmd_exists 'docker compose'; then
        docker compose ps --format json --quiet 2>/dev/null | \
            zsh -c 'readarray -t services <@-; echo "${services[1],}"'
    elif _cmd_exists 'docker-compose'; then
        docker-compose ps --format json --quiet 2>/dev/null | \
            zsh -c 'readarray -t services <@-; echo "${services[1],}"'
    fi
}

# =============================================================================
# CORE EXECUTION ENGINE
# =============================================================================

_console_exec() {
    local args=("$@")
    local execution_method="none"
    
    # Priority 1: Active Docker container
    if _file_exists "./docker-compose.yml" && \
       [[ -n "$( _parse_docker_services )" ]]; then
        local container
        container="$( _parse_docker_services )"
        if [[ -n "$container" ]]; then
            _log "Executing in Docker container: ${container}"
            docker compose exec "${container}" php bin/console "${args[@]}"
            return $?
        fi
    fi
    
    # Priority 2: Symfony CLI with requirements check
    if _cmd_exists 'symfony'; then
        if symfony check:requirements >/dev/null 2>&1; then
            _log "Executing via Symfony CLI"
            symfony console "${args[@]}"
            return $?
        fi
    fi
    
    # Priority 3: Local bin/console
    if _file_exists "bin/console"; then
        _log "Executing local bin/console"
        php bin/console "${args[@]}"
        return $?
    fi
    
    # Fallback: No installation found
    _log "ERROR: No Symfony installation detected in current directory." >&2
    return 1
}

# =============================================================================
# COMMAND ROUTER
# =============================================================================

symfony() {
    # Local variables to avoid global pollution
    local sub_cmd="${1:-}"
    local rest_args=("${@:2}")
    local choice name db_action
    
    # Validate Symfony path (ensure we're not executing from a library)
    if [[ -z "$sub_cmd" && -n "$1" && ! "$1" =~ ^[a-zA-Z] ]]; then
        sub_cmd="$1"
        rest_args=("${@:2}")
    fi
    
    # Show help if no arguments and not a valid command
    if [[ -z "$sub_cmd" && $# -eq 1 ]]; then
        _log "Symfony Developer Wrapper Tool"
        _log "Usage: symfony [command] [options]"
        _log ""
        _log "Commands:"
        _log "  sf       Run raw symfony/console directives"
        _log "  sfs      Start the development web server"
        _log "  sft      Execute the phpunit test suite"
        _log "  make     Interactive MakerBundle scaffolding"
        _log "  db       Doctrine database management"
        _log "  clear    Clear Symfony and asset caches"
        _log "  sfh      Start server with hot-reload"
        return 0
    fi
    
    # Main command dispatcher
    case "$sub_cmd" in
        # --- Shorthand execution ---
        sf)
            _console_exec "${rest_args[@]}"
            ;;
        sfs)
            if _cmd_exists 'symfony'; then
                symfony server:start "${rest_args[@]}"
            else
                _log "ERROR: Symfony CLI not found. Falling back to built-in server."
                php -S 127.0.0.1:8000 -t public/ "${rest_args[@]}"
            fi
            ;;
        sft)
            _console_exec phpunit "${rest_args[@]}"
            ;;
        sfh)
            # Start server with hot-reload capabilities
            if _cmd_exists 'symfony'; then
                symfony server:start --dir=./public --port=8000 --reload "${rest_args[@]}"
            else
                _log "ERROR: Symfony CLI not found. Using built-in server."
                php -S 127.0.0.1:8000 -t public/ "${rest_args[@]}"
            fi
            ;;
        
        # --- MakerBundle Scaffolding ---
        make)
            # Validate we're in a project root
            if ! _file_exists "bin/console"; then
                _log "ERROR: Not a Symfony project root (no bin/console found)." >&2
                return 1
            fi
            
            _log "Choose a component to scaffold:"
            _log "  1) Entity (Database Model)"
            _log "  2) Controller"
            _log "  3) Form Class"
            _log "  4) CRUD Interface (Full scaffolding)"
            _log "  5) Data Fixture Set"
            _log "  9) Quit without scaffolding"
            
            _log -n "Enter choice [1-9]: "
            read -r choice
            
            if ! [[ "$choice" =~ ^[1-9]$ ]]; then
                _log "ERROR: Invalid choice." >&2
                return 1
            fi
            
            _log -n "Enter name (e.g., Product): "
            read -r name
            
            case "$choice" in
                1) _console_exec make:entity "$name" ;;
                2) _console_exec make:controller "${name}Controller" ;;
                3) _console_exec make:form "${name}Type" ;;
                4) _console_exec make:crud "$name" ;;
                5) _console_exec make:fixtures "${name}Fixtures" ;;
                9) ;;
                *)
                    _log "ERROR: Invalid selection." >&2
                    return 1
                    ;;
            esac
            ;;
        
        # --- Database & Doctrine Management ---
        db)
            if [[ $# -ge 2 ]]; then
                db_action="${1}"
                rest_args=("${@:2}")
            else
                _log "Database Management Sub-commands:"
                _log "  symfony db create      Create the database"
                _log "  symfony db drop        Drop the database schema"
                _log "  symfony db diff        Generate new migration from entity changes"
                _log "  symfony db migrate     Run pending schema migrations"
                _log "  symfony db status      View migration milestones"
                _log "  symfony db fixtures    Load structural test data"
                _log "  symfony db fresh       Drop, recreate, migrate, and seed"
                return 0
            fi
            
            case "$db_action" in
                create)     _console_exec doctrine:database:create "${rest_args[@]}" ;;
                drop)       _console_exec doctrine:database:drop --force "${rest_args[@]}" ;;
                diff)       _console_exec make:migration "${rest_args[@]}" ;;
                migrate)    _console_exec doctrine:migrations:migrate --no-interaction "${rest_args[@]}" ;;
                status)     _console_exec doctrine:migrations:status "${rest_args[@]}" ;;
                fixtures)   _console_exec doctrine:fixtures:load --no-interaction "${rest_args[@]}" ;;
                fresh)
                    _log "Rebuilding database configuration from scratch..."
                    _console_exec doctrine:database:drop --force --if-exists
                    _console_exec doctrine:database:create
                    _console_exec doctrine:migrations:migrate --no-interaction
                    _console_exec doctrine:fixtures:load --no-interaction
                    ;;
                *)
                    _log "ERROR: Invalid database action: $db_action" >&2
                    return 1
                    ;;
            esac
            ;;
        
        # --- Cache Management ---
        clear)
            if [[ $# -ge 2 ]]; then
                local cache_type="${1}"
                rest_args=("${@:2}")
            else
                _log "Clearing Symfony and asset caches..."
                # Clear PHP/Symfony runtime cache
                if _file_exists ".cache" && [[ -d ".cache" ]]; then
                    _log "Clearing runtime cache..."
                    rm -rf .cache/* 2>/dev/null
                fi
                # Clear container debug cache
                if _file_exists "var/cache"; then
                    _log "Clearing container cache..."
                    rm -rf var/cache/*
                fi
                # Compile assets (if installed)
                if _file_exists "assets.json" || _file_exists "composer.json"; then
                    _log "Compiling assets..."
                    if _cmd_exists 'composer'; then
                        composer dump-autoload --optimize --classmap-authoritative
                    fi
                    if _cmd_exists 'symfony'; then
                        symfony asset:install 2>/dev/null || true
                    fi
                fi
            else
                _console_exec cache:clear --no-warmup "${rest_args[@]}"
                if _cmd_exists 'symfony'; then
                    symfony asset:install 2>/dev/null || true
                fi
            fi
            ;;
        
        # --- Default ---
        *)
            _log "ERROR: Unknown sub-command: $sub_cmd" >&2
            
            # Try to execute as raw console command
            if [[ ! "$sub_cmd" =~ ^(sf|sfs|sft|sfh|make|db|clear)$ ]]; then
                _console_exec "${sub_cmd[@]}" "${rest_args[@]}"
            else
                _log "Available commands: sf, sfs, sft, sfh, make, db, clear" >&2
            fi
            ;;
    esac
    
    return $?
}

# =============================================================================
# INITIALIZATION
# =============================================================================

# Export function for shell completion
complete -F _symfony_complete symfony

_symfony_complete() {
    # Basic completion - can be expanded
    local cur="${COMP_WORDS[COMP_CWORD]}"
    COMPREPLY=( $(compgen -W "sf sfs sft sfh make db clear" -- "$cur") )
}

# Allow command to be invoked directly
eval "symfony()"