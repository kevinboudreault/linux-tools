#!/usr/bin/env zsh

server_debug() {
	# Ensure the script is run with root/sudo privileges
	if [ "$EUID" -ne 0 ]; then
	  echo "[-] Please run as root (sudo) to access logs and system states."
	  exit 1
	fi

	REPORT_DIR="/var/log/server_debug_reports"
	REPORT_FILE="$REPORT_DIR/debug_report_$(date +%Y%m%d_%H%M%S).txt"

	mkdir -p "$REPORT_DIR"
	exec > >(tee -a "$REPORT_FILE") 2>&1

	echo "=========================================="
	echo "= SERVER HEALTH CHECK - $(date)"
	echo "=========================================="

	echo "\n--- 1. SYSTEM LOAD & UPTIME ---"
	uptime
	top -b -n 1 | head -n 15

	echo "\n--- 2. MEMORY USAGE ---"
	free -m

	echo "\n--- 3. DISK SPACE ---"
	df -h

	echo "\n--- 4. TOP CPU/MEMORY PROCESSES ---"
	ps aux --sort=-%cpu | head -n 10

	echo "\n--- 5. ACTIVE CONNECTIONS ---"
	ss -ant | awk '{print $1}' | sort | uniq -c
	ss -tnap | grep -E 'ESTAB|CLOSE_WAIT' | wc -l

	echo "\n--- 6. WEB SERVER LOGS (Last 50 Lines) ---"
	# Check for Caddy via systemd, followed by standard paths for Nginx/Apache
	if systemctl is-active --quiet caddy; then
	    echo "[+] Caddy service detected. Fetching journal logs..."
	    journalctl -u caddy -n 50 --no-pager
	elif [ -f /var/log/nginx/error.log ]; then
	    echo "[+] Nginx error logs found."
	    tail -n 50 /var/log/nginx/error.log
	elif [ -f /var/log/apache2/error.log ]; then
	    echo "[+] Apache error logs found."
	    tail -n 50 /var/log/apache2/error.log
	else
	    echo "[-] No running Caddy service or standard Nginx/Apache logs found."
	fi

	echo "\n--- 7. SYSLOG / KERNEL OOM KILLER (Last 30 Lines) ---"
	if [ -f /var/log/syslog ]; then
	    tail -n 30 /var/log/syslog | grep -E 'oom-killer|error|fail|crit'
	else
	    journalctl -k -n 30 --no-pager | grep -E 'oom-killer|error|fail|crit'
	fi

	echo "\n--- 8. FIREWALL STATUS (UFW) ---"
	ufw status verbose

	echo "\n=========================================="
	echo "= DIAGNOSTIC COMPLETE. Saved to: $REPORT_FILE"
	echo "=========================================="
}
