#!/usr/bin/env zsh


# =============================================================================
# File: check_caddy_geoip
# Description: Check caddy connection log for IP lookup
# Usage: Check where the connection to caddy comes from
# =============================================================================

check_caddy_geoip(){

    set -euo pipefail

    # === Configuration ===
    readonly LOG_DIR="${1:-/var/log/caddy}"
    readonly DEFAULT_LINES=100

    # Ensure required tools exist (fail fast if missing)
    if ! command -v geoiplookup &>/dev/null; then
        echo "[-] Error: Required tool 'geoiplookup' is not found in PATH." >&2
        echo "[-] Hint: sudo dnf install GeoIP" >&2
        return 1
    fi

    if ! command -v jq &>/dev/null; then
        echo "[-] Error: Required tool 'jq' is not found in PATH." >&2
        return 1
    fi

    # === Function Definitions ===

    # Parse a single JSON log line safely
    parse_line() {
        local line="$1"
        local country="$2"

        # Skip lines that aren't valid JSON or empty
        if ! echo "$line" | jq -e 'type == "object" | .request.remote_ip' >/dev/null 2>&1; then
            return 0
        fi

        local ip="$(echo "$line" | jq -r '.request.remote_ip' // empty)"
        local host="$(echo "$line" | jq -r '.request.host' // "unknown")"
        local uri="$(echo "$line" | jq -r '.request.uri' // "/")"
        local status="$(echo "$line" | jq -r '.status' // "200")"
        
        # Handle timestamp conversion
        local ts_raw="$(echo "$line" | jq -r '.ts' // empty)"
        local readable_ts="N/A"
        if [[ -n "$ts_raw" ]]; then
            # Remove fractional seconds for GNU date compatibility
            local ts_int="${ts_raw%.*}"
            if [[ -n "$ts_int" ]]; then
                readable_ts="$(date -d "@${ts_int}" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo 'N/A')"
            fi
        fi

        # Determine country
        if [[ -z "$country" ]]; then
            country="$(geoiplookup "$ip" 2>/dev/null | sed 's/GeoIP Country Edition: //g' | xargs 2>/dev/null)"
        fi

        # Fallback for private IPs or errors
        if [[ "$country" == *"IP Address not found"* || -z "$country" ]]; then
            country="Internal/Unknown"
        fi

        # Output formatted string
        printf "  [%s] - %-15s (%-12s) -> %-15s | %s %s\n" \
            "${readable_ts:-N/A}" "$ip" "$country" "$host" "$status" "$uri"
    }

    # === Main Execution ===

    # Check directory existence
    if [[ ! -d "$LOG_DIR" ]]; then
        echo "[-] Error: Log directory '$LOG_DIR' does not exist." >&2
        return 1
    fi

    # Find matching log files using extended globbing
    # -N : Don't follow symlinks, -o : Nullglob (return nothing if no match)
    shopt -s extglob nullglob
    mapfile -t log_files < <(find "$LOG_DIR" -maxdepth 1 -type f -name "*.access.log")

    if (( ${#log_files[@]} == 0 )); then
        echo "[-] No files ending with '.access.log' found in '$LOG_DIR'." >&2
        return 0
    fi

    echo "===== Processing Caddy Connections ====="
    echo "Format: [Timestamp] - IP (Country) -> Host | Status Path"
    echo "========================================"

    total_lines=0
    echo "Total JSON records processed: $total_lines"
}
