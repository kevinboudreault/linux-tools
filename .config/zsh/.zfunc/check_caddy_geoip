#!/usr/bin/env zsh


# =============================================================================
# File: check_caddy_geoip
# Description: Check caddy connection log for IP lookup
# Usage: Check where the connection to caddy comes from
# =============================================================================

check_caddy_geoip(){

    # Define the directory containing your Caddy logs
    LOG_DIR="/var/log/caddy"

    # Ensure the log directory exists
    if [[ ! -d "$LOG_DIR" ]]; then
        echo "[-] Error: Log directory not found at $LOG_DIR"
        return 1
    fi

    # Ensure geoiplookup is installed on Fedora
    if ! command -v geoiplookup &> /dev/null; then
        echo "[-] Error: 'geoiplookup' is not installed. Run: sudo dnf install GeoIP"
        return 1
    fi

    # Find all files ending with .access.log in the target directory
    # Using Zsh globbing (*.access.log)
    log_files=(${LOG_DIR}/*.access.log(N))

    # Check if any matching log files were found
    if (( ${#log_files} == 0 )); then
        echo "[-] No files ending with '.access.log' found in $LOG_DIR"
        return 0
    fi

    echo "=== Processing Caddy Connections ==="
    echo "Format: [Timestamp] - IP (Country) -> Host | Status Path"
    echo "===================================="

    # Loop through each discovered log file
    for log_file in "${log_files[@]}"; do
        echo "Reading: ${log_file:t} ..."

        # Read the log file line by line (Caddy uses one JSON object per line)
        tail -n 100 "$log_file" | while read -r line; do
            # Extract data using jq, safeguarding against empty values
            local ip=$(echo "$line" | jq -r '.request.remote_ip // empty')
            local host=$(echo "$line" | jq -r '.request.host // "unknown"')
            local uri=$(echo "$line" | jq -r '.request.uri // "/"')
            local status=$(echo "$line" | jq -r '.status // 200')
            local ts=$(echo "$line" | jq -r '.ts // empty')

            # Skip processing if no IP is found
            if [[ -z "$ip" ]]; then
                continue
            fi

            # Convert Unix timestamp to readable date (Fedora uses GNU date syntax)
            local readable_ts=""
            if [[ -n "$ts" ]]; then
                readable_ts=$(date -d "@${ts%.*}" "+%Y-%m-%d %H:%M:%S" 2>/dev/null)
            fi

            # Resolve Country via local Fedora geoiplookup utility
            # Strips out "GeoIP Country Edition: " header and trims spaces
            # Use free online API for ip lookup
            # local country=$(curl -s --connect-timeout 2 "http://ip-api.com{ip}" | jq -r '.country // "Unknown Country"')
            # Use local database for ip lookup
            local country=$(geoiplookup "$ip" | sed 's/GeoIP Country Edition: //g' | xargs)

            # Fallback if the IP is local/private or unresolvable
            if [[ "$country" == *"IP Address not found"* || -z "$country" ]]; then
                country="Internal/Unknown"
            fi

            # Output the enriched log entry
            print "[$readable_ts] - $ip ($country) -> $host | $status $uri"
        done
        echo "------------------------------------"
    done
}
