#!/usr/bin/env zsh

# ==========================================
# Zsh Check Loki logs
# ==========================================
check_loki(){
  # --- CONFIGURATION ---
  LOKI_CONTAINER="loki"                # Name of your Loki Docker container
  LOKI_URL="http://localhost:3101"     # Address of your Loki instance
  DOCKER_IMAGE="grafana/loki:latest"   # Logcli is embedded in Loki docker images

  # --- USAGE ---
  if [ $# -eq 0 ]; then
      echo "Usage: $0 \"<LogQL_Query>\""
      echo "Example: $0 '{job=\"docker\"} |= \"error\"'"
      return 1
  fi

  QUERY=$1

  # --- EXECUTION ---
  echo "Searching Loki container '${LOKI_CONTAINER}'..."
  echo "Query: $QUERY"
  echo "----------------------------------------"

  # Run logcli via an ephemeral docker container
  docker run --rm \
    --network container:${LOKI_CONTAINER} \
    ${DOCKER_IMAGE} \
    logcli query --addr=${LOKI_URL} "${QUERY}"
}
