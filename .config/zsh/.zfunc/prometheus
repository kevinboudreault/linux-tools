#!/usr/bin/env zsh

PROM_URL="http://localhost:9090/api/v1/query"
QUERY="up"

# Fetch metric data using curl
response=$(curl -s --data-urlencode "query=$QUERY" "$PROM_URL")

# Parse JSON results (requires 'jq')
echo "Active Targets:"
echo "$response" | jq '.data.result[] | {instance: .metric.instance, status: .value[1]}'
