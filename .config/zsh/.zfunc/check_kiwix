#!/usr/bin/env zsh

# ==========================================
# Zsh Check Kiwix Latest Wikipedia
# ==========================================
 
check_kiwix() {	
	# The directory containing English Wikipedia ZIM files
	local BASE_URL="${1:-https://download.kiwix.org/zim/wikipedia/}"

	# Define the specific flavor you want (e.g., all_maxi, all_nopic, etc.)
	# 'all_maxi' includes everything: text and images.
	local FLAVOR="${2:-wikipedia_en_all_maxi}"

	print "Checking for the latest version of $FLAVOR..."

	# Fetch raw output and check success
	local RAW_OUTPUT=$(curl -sfL "$BASE_URL")
	if [[ $? -ne 0 ]]; then
		print "Error: Failed to reach $BASE_URL"
		return 1
	fi

	# Extract filenames and find the most recent one
	local LATEST_FILE=$(echo "$RAW_OUTPUT" | grep -oE "${FLAVOR}_[0-9]{4}-[0-9]{2}\.zim" | sort -r | head -n 1)

	if [[ -n "$LATEST_FILE" ]]; then
		print "Latest Version: $LATEST_FILE"
		print "Download URL:   ${BASE_URL}${LATEST_FILE}"
	else
		print "Error: No valid .zim file found for $FLAVOR. Check your internet connection or flavor name."
		return 1
	fi
}
